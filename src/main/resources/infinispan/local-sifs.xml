<?xml version="1.0" encoding="UTF-8"?>
<infinispan
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="urn:infinispan:config:15.0 https://www.infinispan.org/schemas/infinispan-config-15.0.xsd"
        xmlns="urn:infinispan:config:15.0">

    <jgroups>
        <stack-file name="jgroupsStack" path="${jgroups.stack:jgroups-tcp.xml}"/>
    </jgroups>

    <cache-container name="default" default-cache="perf-cache">
        <transport stack="jgroupsStack" lock-timeout="600000" cluster="default" />
        <jmx>
            <property name="enabled">true</property>
        </jmx>
        <local-cache name="perf-cache">
            <persistence>
                <file-store path="target/sifs-data/${perf.node.id:default}">
                    <write-behind />
                </file-store>
            </persistence>
        </local-cache>
    </cache-container>
</infinispan>
