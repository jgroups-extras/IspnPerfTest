
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="urn:org:jgroups"
        xsi:schemaLocation="urn:org:jgroups http://www.jgroups.org/schema/jgroups.xsd">
   <include file="${transport-config:jgroups-tcp-default.xml}"/>
   <!-- Infinispan can only have *2* variables in a list -->
   <TCPPING
        initial_hosts_file="hosts.txt"
        port_range="${tcpping.port_range,env.PORT_RANGE:0}"/>
   <MERGE3 max_interval="30000"
           min_interval="10000"/>
   <FD_SOCK2 offset="20" port_range="0" connect_timeout="300"/>
   <FD_ALL3 timeout="60000" interval="10000"/>
   <VERIFY_SUSPECT2 timeout="1.5s"/>
   <NAKACK4 xmit_interval="${nakack.xmit_interval:0.5s}"
            capacity="${nakack.capacity:16384}"/>
   <UNICAST4 xmit_interval="${unicast.xmit_interval:0.5s}"
             capacity="${unicast.capacity:9000}"/>
   <pbcast.GMS print_local_addr="true"
               join_timeout="1s"/>
   <FRAG4 frag_size="60K"/>
</config>
